# Application
APP_ENV=dev
APP_SECRET=change_me_to_a_random_32_char_string

# Database
POSTGRES_DB=money_manager
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me

# JWT (clés générées par devops/generate-jwt-keys.sh)
JWT_PASSPHRASE=change_me

# RabbitMQ
RABBITMQ_USER=app
RABBITMQ_PASSWORD=change_me
RABBITMQ_VHOST=money_manager

# Sentry (optionnel — docker-compose.sentry.yml)
SENTRY_DSN=
SENTRY_SECRET_KEY=change_me_to_a_random_50_char_string
SENTRY_POSTGRES_DB=sentry
SENTRY_POSTGRES_USER=sentry
SENTRY_POSTGRES_PASSWORD=change_me
